{
  "name": "@nghien-ot/rux",
  "type": "module",
  "description": "A declarative, type-safe HTTP client for TypeScript with zero runtime dependencies.",
  "keywords": [
    "http",
    "client",
    "typescript",
    "declarative",
    "type-safe",
    "zero-runtime-dependencies"
  ],
  "version": "0.1.2-dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nghien-ot/rux.git"
  },
  "bugs": {
    "url": "https://github.com/nghien-ot/rux/issues"
  },
  "homepage": "https://github.com/nghien-ot/rux#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck",
    "qa:manual": "bun run build && bun test ./.qa/text.ts"
  },
  "devDependencies": {
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {}
}